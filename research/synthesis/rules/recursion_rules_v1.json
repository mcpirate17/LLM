{
  "schema_version": "recursion_rules_v1",
  "description": "Recursion placement rules for dynamic component chains.",
  "recursion_ops": [
    "fixed_point_iter",
    "mixture_of_recursions",
    "depth_gated_transform",
    "score_depth_blend",
    "depth_weighted_proj"
